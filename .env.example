# ─────────────────────────────────────────────────────────────────────────────
# Expense Sharing App — Environment Variables
# Copy this file to .env and fill in the values before running the app.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Full async PostgreSQL connection URL.
# Format: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
# When running via docker-compose, the host is the service name "db".
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/splitvice

# PostgreSQL credentials (used by docker-compose to initialise the DB container)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=splitvice

# ── Authentication ────────────────────────────────────────────────────────────
# Secret key used to sign JWT tokens.
# MUST be at least 32 characters. Generate a strong value with:
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-to-a-random-string-of-at-least-32-characters

# JWT signing algorithm. HS256 is the default and recommended for single-server use.
JWT_ALGORITHM=HS256

# How long (in minutes) an access token remains valid. Default: 15 minutes.
ACCESS_TOKEN_EXPIRE_MINUTES=15

# How long (in days) a refresh token remains valid. Default: 7 days.
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Application ───────────────────────────────────────────────────────────────
# Set to true to enable SQLAlchemy query logging and FastAPI debug mode.
# Always false in production.
DEBUG=false

# Application version string (informational, shown in /api/v1/docs).
APP_VERSION=0.1.0

# Environment name. Set to "production" in production deployments.
# Controls: secure cookies, log format, Sentry activation.
ENV=development

# Comma-separated list of trusted hostnames (used in production).
# Example: "splitvice.example.com,www.splitvice.example.com"
ALLOWED_HOSTS=*

# ── Sentry (optional) ─────────────────────────────────────────────────────────
# Leave empty to disable error tracking (default for local development).
# Get your DSN from https://sentry.io
SENTRY_DSN=
